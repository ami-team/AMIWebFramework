<style type="text/css">

#FEF9E8D8_D4AB_B545_B394_C12DD5817D61 table th,
#FEF9E8D8_D4AB_B545_B394_C12DD5817D61 table td,
#FEF9E8D8_D4AB_B545_B394_C12DD5817D61 table span {
	font-size: 14px;
	min-height: 1.25rem;
	white-space: nowrap;
}

#CDE5AD14_1268_8FA7_F5D8_0D690F3FB850,
#FEF9E8D8_D4AB_B545_B394_C12DD5817D61 .edit-mode {
	display: none;
}

/**/

@media (min-width: 576px) {

	#F4B10C5C_47BC_2093_5269_EA03881409FA .input-group {
		max-width: 300px;
	}
}

