{% for bookmark in bookmarks %}
{%   if bookmark.expire === '0' %}
<div class="d-flex" data-id="{{ bookmark.id|e }}">

	<span class="flex-shrink-1" style="cursor: grab;">
		<i class="bi bi-hand-index-thumb text-secondary {% if BOOTSTRAP_VERSION === 'v5' %}me-2{% else %}mr-2{% endif %}"></i>
	</span>

	<span class="w-100" style="cursor: pointer;" onclick="bookmarkEditorApp.select('{{ bookmark.id|e }}');">
		{{ bookmark.name|e }}
	</span>

	<span class="flex-shrink-1" style="cursor: pointer;">
		<a href="{{WEBAPP_URL}}?v={{ bookmark.hash|e }}" target="_blank" style="white-space: nowrap;">
			<i class="bi bi-link-45deg"></i> goto
		</a>
	</span>

</div>
{%   endif %}
{% endfor %}
