<div class="row">

	<!-- *********************************************************************************************************** -->

	<div class="col-md-1 col-lg-2 col-xl-3 text-center">
		<img class="d-none d-xl-inline" src="{{ORIGIN_URL}}/js/assets/images/padlock.png" alt="" style="height:180px;" />
	</div>

	<!-- *********************************************************************************************************** -->

	<div class="col-md-10 col-lg-8 col-xl-6 text-center">
		<div class="card mb-4">
			<div class="card-body text-{% if BOOTSTRAP_VERSION === 'v5' %}start{% else %}left{% endif %}">
				<form id="C12ED50C_4BF7_DAD3_C698_DE0DCBB3228C">
					{% if user %}
						<input type="hidden" name="user" value="{{ user|e }}" id="A5A54104_A082_094F_F88C_10333C985981" />
					{% else %}
						<div class="mb-2">
							<label class="form-label" for="A5A54104_A082_094F_F88C_10333C985981">Login<span class="text-danger">*</span></label>
							<input class="form-control form-control-sm" type="text" name="user" id="A5A54104_A082_094F_F88C_10333C985981" required="required" placeholder="Type your login..." />
						</div>
					{% endif %}
					{% if old_pass %}
						<input type="hidden" name="old_pass" value="{{ old_pass|e }}" id="F6520017_DBEB_C555_6D06_0E50AA50C43C" />
					{% else %}
						<div class="mb-2">
							<label class="form-label" for="F6520017_DBEB_C555_6D06_0E50AA50C43C">Old password<span class="text-danger">*</span></label>
							<input class="form-control form-control-sm" type="password" name="old_pass" id="F6520017_DBEB_C555_6D06_0E50AA50C43C" required="required" placeholder="Type your old password..." />
						</div>
					{% endif %}
					<div class="mb-2">
						<label class="form-label" for="F956453E_2AB6_9397_4976_A11EE21B8FAB">New password<span class="text-danger">*</span></label>
						<input class="form-control form-control-sm" type="password" name="new_pass" id="F956453E_2AB6_9397_4976_A11EE21B8FAB" required="required" placeholder="Choose a new password..." />
					</div>
					<div class="mb-2">
						<label class="form-label" for="EB5C35F7_F6E0_9B1E_E356_9FB235003814">New password<span class="text-danger">*</span></label>
						<input class="form-control form-control-sm" type="password" name="xxxxxxxx" id="EB5C35F7_F6E0_9B1E_E356_9FB235003814" required="required" placeholder="Type your new password again..." />
					</div>
				</form>
			</div>
			<div class="card-footer text-{% if BOOTSTRAP_VERSION === 'v5' %}end{% else %}right{% endif %}">
				<button class="btn btn-outline-secondary" type="reset" form="C12ED50C_4BF7_DAD3_C698_DE0DCBB3228C">Reset</button>
				-
				<button class="btn btn-primary" type="submit" form="C12ED50C_4BF7_DAD3_C698_DE0DCBB3228C">Apply</button>
			</div>
		</div>
	</div>

	<!-- *********************************************************************************************************** -->

	<div class="col-md-1 col-lg-2 col-xl-3 text-center">
		<img class="d-none d-xl-xxxxxx" src="{{ORIGIN_URL}}/js/assets/images/padlock.png" alt="" style="height: 180px;" />
	</div>

	<!-- *********************************************************************************************************** -->

</div>
