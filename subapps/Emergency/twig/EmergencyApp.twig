<div class="row m-3">

	<!-- *********************************************************************************************************** -->

	<div class="col-md-1 col-lg-2 col-xl-3 text-center p-0">
		<img class="d-none d-xl-inline" src="{{ORIGIN_URL}}/subapps/Emergency/images/emergency.png" alt="Emergency" style="height: 360px;" />
	</div>

	<!-- *********************************************************************************************************** -->

	<div class="col-md-10 col-lg-8 col-xl-6 text-center p-0">
		<div class="card mb-4">
			<div class="card-body text-{% if BOOTSTRAP_VERSION > 4 %}start{% else %}left{% endif %}">
				<div class="form-group">
					<label class="form-label" for="C51A09D0_6E2A_0CFA_83C8_9ABC1E2EAA75">
						Message (<span class="text-danger">160 characters max</span>)
					</label>
					<textarea class="form-control" rows="8" id="C51A09D0_6E2A_0CFA_83C8_9ABC1E2EAA75"></textarea>
				</div>
			</div>
			<div class="card-footer text-{% if BOOTSTRAP_VERSION > 4 %}end{% else %}right{% endif %}">
				<i class="fa fa-exclamation-triangle"></i>&nbsp;For&nbsp;blocking&nbsp;issues&nbsp;only...
				<button class="btn btn-danger ml-2" type="button" id="A64EBE51_FD59_AAC3_BC5C_7CCC62F413B9" onclick="emergencyApp.send($('#C51A09D0_6E2A_0CFA_83C8_9ABC1E2EAA75').val());">
					Send message
				</button>
			</div>
		</div>
	</div>

	<!-- *********************************************************************************************************** -->

	<div class="col-md-1 col-lg-2 col-xl-3 text-center p-0">
		<img class="d-none d-xl-xxxxxx" src="{{ORIGIN_URL}}/subapps/Emergency/images/emergency.png" alt="Emergency" style="height: 360px;" />
	</div>

	<!-- *********************************************************************************************************** -->

</div>
